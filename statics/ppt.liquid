    <script>
      document.addEventListener("alpine:init", () => {
        Alpine.data("presentation", () => ({
          currentIndex: 0,
          menuOpen: false,
          swiper: null,
          slides: [
            "What: 一句话介绍",
            "Why: 企业 3 个痛点",
            "Who: 目标客户群体",
            "4 大应用场景",
            "12 大产品组合",
            "800 家客户案例",
            "核心竞争优势",
            "竞品对比分析",
            "平台架构设计",
            "平台使用流程",
            "部署实施：SaaS/私有",
            "私有化环境要求",
            "数字体验成熟度",
            "企业 ROI 投资回报",
            "AI 远景规划",
            "结语",
          ],
          get progress() {
            const total = this.slides.length || 16;
            const current = this.currentIndex || 0;
            if (!total || total === 0) {
              return 0;
            }
            const percentage = ((current + 1) / total) * 100;
            const result = Math.min(Math.max(percentage, 0), 100);
            return isNaN(result) ? 0 : result;
          },
          initApp() {
            this.swiper = new Swiper(".mySwiper", {
              effect: "slide", // 使用 slide 效果以显示间距
              slidesPerView: 1,
              allowTouchMove: false, // Prevent accidental swipes, use controls
              speed: 600, // 切换速度
              keyboard: {
                enabled: true,
                onlyInViewport: true,
              },
              on: {
                slideChange: (s) => {
                  this.currentIndex = s.activeIndex;
                  // 强制更新进度条（确保响应式更新）
                  this.$nextTick(() => {
                    // 触发响应式更新
                  });
                },
              },
            });

            // 添加键盘事件监听（左右方向键控制翻页）
            const handleKeyDown = (e) => {
              if (!this.swiper) return;

              // 左方向键或上方向键：上一张
              if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
                e.preventDefault();
                this.swiper.slidePrev();
              }
              // 右方向键或下方向键：下一张
              else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
                e.preventDefault();
                this.swiper.slideNext();
              }
              // Home 键：第一张
              else if (e.key === 'Home') {
                e.preventDefault();
                this.swiper.slideTo(0);
              }
              // End 键：最后一张
              else if (e.key === 'End') {
                e.preventDefault();
                this.swiper.slideTo(this.slides.length - 1);
              }
            };

            document.addEventListener('keydown', handleKeyDown);
          },
          goToSlide(index) {
            this.swiper.slideTo(index);
            this.menuOpen = false;
          },
        }));
      });
    </script>
