              >
                <p class="text-primary font-bold">
                  AI 驱动：全模块支持智能搜索、自动摘要、对话问答及智能标签。
                </p>
              </div>
            </div>
          </div>

          <!-- Slide 6: Customers -->
          <div class="swiper-slide">
            <div
              class="w-full h-full bg-white/60 backdrop-blur-xl rounded-3xl p-4 shadow-2xl border border-white/20 overflow-auto relative flex flex-col"
