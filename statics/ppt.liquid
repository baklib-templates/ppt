              </header>

              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <!-- Group 1 -->
                <div class="bg-slate-50 rounded-xl p-4 border border-slate-200">
                  <h3
                    class="text-primary font-bold text-lg mb-4 border-b pb-2 border-slate-200"
                  >
                    知识库管理
                  </h3>

                  <ul class="space-y-2 text-sm text-slate-700">
                    <li class="bg-white p-2 rounded shadow-sm">企业 Wiki</li>
                    <li class="bg-white p-2 rounded shadow-sm">AI 知识库</li>
                    <li class="bg-white p-2 rounded shadow-sm">API 文档</li>
                    <li class="bg-white p-2 rounded shadow-sm">产品手册</li>
                  </ul>
                </div>

                <!-- Group 2 -->
                <div class="bg-slate-50 rounded-xl p-4 border border-slate-200">
                  <h3
                    class="text-primary font-bold text-lg mb-4 border-b pb-2 border-slate-200"
                  >
                    品牌门户
                  </h3>

                  <ul class="space-y-2 text-sm text-slate-700">
                    <li class="bg-white p-2 rounded shadow-sm">品牌官网</li>
                    <li class="bg-white p-2 rounded shadow-sm">多语言门户</li>
                    <li class="bg-white p-2 rounded shadow-sm">资源中心</li>
                    <li class="bg-white p-2 rounded shadow-sm">团队博客</li>
                  </ul>
                </div>

                <!-- Group 3 -->
                <div class="bg-slate-50 rounded-xl p-4 border border-slate-200">
                  <h3
                    class="text-primary font-bold text-lg mb-4 border-b pb-2 border-slate-200"
                  >
                    服务与社区
                  </h3>

                  <ul class="space-y-2 text-sm text-slate-700">
                    <li class="bg-white p-2 rounded shadow-sm">帮助中心</li>
                    <li class="bg-white p-2 rounded shadow-sm">客服知识库</li>
                    <li class="bg-white p-2 rounded shadow-sm">问答社区</li>
                    <li class="bg-white p-2 rounded shadow-sm">学习培训 LMS</li>
                  </ul>
                </div>

                <!-- Group 4 -->
                <div class="bg-slate-50 rounded-xl p-4 border border-slate-200">
                  <h3
                    class="text-primary font-bold text-lg mb-4 border-b pb-2 border-slate-200"
                  >
                    数字出版
                  </h3>

                  <ul class="space-y-2 text-sm text-slate-700">
                    <li class="bg-white p-2 rounded shadow-sm">在线方案书</li>
                    <li class="bg-white p-2 rounded shadow-sm">数字出版物</li>
                    <li class="bg-white p-2 rounded shadow-sm">电子杂志</li>
                    <li class="bg-white p-2 rounded shadow-sm">H5 海报</li>
                  </ul>
                </div>
              </div>

              <div
