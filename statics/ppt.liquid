                </div>

                <div
                  class="aspect-video bg-white shadow-md rounded-lg flex items-center justify-center border border-slate-100"
                >
                  <span class="text-2xl font-bold text-slate-400">
                    Dianxiaomi
                  </span>
                </div>

                <div
