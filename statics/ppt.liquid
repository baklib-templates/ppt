
  <body
    x-data="presentation()"
    x-init="initApp()"
    class="h-screen w-screen overflow-hidden flex flex-col items-center justify-center relative text-slate-800 bg-primary-100"
  >
    <!-- Floating Navigation Menu -->
    <div
      class="fixed top-6 left-8 z-50 group"
      @mouseenter="menuOpen = true"
      @mouseleave="menuOpen = false"
    >
      <div
        class="flex items-center gap-2 bg-white/80 backdrop-blur-xl shadow-lg border border-white/20 px-4 py-2 rounded-full cursor-pointer hover:shadow-xl hover:bg-white/90 transition-all text-slate-700 hover:text-primary"
      >
        <i class="fas fa-th-large w-5 h-5"></i>
        <span class="font-bold text-sm">目录</span>
      </div>

      <div
        x-show="menuOpen"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 translate-y-2"
        x-transition:enter-end="opacity-100 translate-y-0"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100 translate-y-0"
        x-transition:leave-end="opacity-0 translate-y-2"
        class="absolute top-full left-0 pt-4 w-[400px]"
        style="display: none"
      >
        <div
          class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/20 p-4 max-h-[70vh] overflow-y-auto no-scrollbar"
        >
          <div class="grid grid-cols-2 gap-2">
            {% assign slide_titles = "What: 一句话介绍,Why: 企业 3 个痛点,Who: 目标客户群体,4 大应用场景,12 大产品组合,800 家客户案例,核心竞争优势,竞品对比分析,平台架构设计,平台使用流程,部署实施：SaaS/私有,私有化环境要求,数字体验成熟度,企业 ROI 投资回报,AI 远景规划,结语" | split: "," %}
            {% for title in slide_titles %}
              <button
                @click="goToSlide({{ forloop.index0 }})"
                class="text-left px-3 py-2 rounded-lg text-xs font-medium transition-colors flex items-center gap-2 w-full"
                :class="currentIndex === {{ forloop.index0 }} ? 'bg-primary text-white shadow-sm' : 'text-slate-600 hover:bg-slate-100'"
              >
                <span
                  class="w-5 h-5 flex items-center justify-center rounded-full text-[10px] shrink-0"
                  :class="currentIndex === {{ forloop.index0 }} ? 'bg-white/20' : 'bg-slate-200 text-slate-500'"
                >{{ forloop.index }}</span>

                <span class="truncate">{{ title }}</span>
              </button>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>

    <!-- Main Swiper Container -->
    <div class="w-full h-full relative z-10 p-4 pb-20">
      <div class="swiper mySwiper w-full h-full">
        <div class="swiper-wrapper">
          <!-- Slide 1: What -->
          <div class="swiper-slide">
            <div
              class="w-full h-full bg-white/60 backdrop-blur-xl rounded-3xl p-4 shadow-2xl border border-white/20 overflow-auto relative flex flex-col"
            >

              <div
                class="flex-1 flex flex-col justify-center items-center text-center mt-8"
              >
                <div
                  class="bg-primary text-white p-6 rounded-full mb-8 shadow-lg shadow-teal-200"
                >
                  <i class="fas fa-box w-16 h-16"></i>
                </div>

                <h2
                  class="text-4xl md:text-6xl font-black text-slate-800 mb-8 leading-tight"
                >
                  一个平台，融合
                  <br />
                  <span class="text-primary">内容</span>、
                  <span class="text-secondary">知识</span> 与
                  <span class="text-accent">体验</span>
                </h2>

                <p
                  class="text-2xl text-slate-600 max-w-4xl mx-auto leading-relaxed"
                >
                  Baklib 是企业级的
                  <strong>All-in-One 云端内容中台</strong
                  >，帮助企业构建全场景的数字体验。打通
                  <strong>资源管理</strong>、 <strong>知识库</strong> 和
                  <strong>应用层</strong>，实现 AI 就绪。
                </p>
              </div>
            </div>
          </div>

          <!-- Slide 2: Why -->
          <div class="swiper-slide">
            <div
              class="w-full h-full bg-white/60 backdrop-blur-xl rounded-3xl p-4 shadow-2xl border border-white/20 overflow-auto relative flex flex-col"
            >
              <div class="absolute top-6 right-8 z-10" x-html="logoSvg"></div>

              <header class="mb-8 border-l-8 border-primary pl-6 pr-20">
                <h1 class="text-4xl font-black text-slate-800 mb-2">
                  为什么选择 Baklib？
                </h1>

                <p class="text-xl text-slate-500 font-light">
                  解决企业内容与知识危机
                </p>
              </header>

              <div
                class="grid grid-cols-1 md:grid-cols-3 gap-8 h-full items-center"
              >
                <!-- Card 1 -->
                <div
                  class="bg-white p-8 rounded-2xl shadow-lg border-t-4 border-secondary h-80 flex flex-col"
                >
                  <div class="text-secondary mb-6">
                    <i class="fas fa-database w-12 h-12"></i>
                  </div>

                  <h3 class="text-2xl font-bold text-slate-800 mb-4">
                    数据孤岛
                  </h3>

                  <p class="text-slate-600">
                    内容分散在本地文件、邮件和互不连通的系统（Word, PDF,
                    Notion），无法集中管理与 AI 训练。
                  </p>
                </div>

                <!-- Card 2 -->
                <div
                  class="bg-white p-8 rounded-2xl shadow-lg border-t-4 border-secondary h-80 flex flex-col"
                >
                  <div class="text-secondary mb-6">
                    <i class="fas fa-chart-line w-12 h-12"></i>
                  </div>

                  <h3 class="text-2xl font-bold text-slate-800 mb-4">
                    研发成本高
                  </h3>

                  <p class="text-slate-600">
                    搭建帮助中心、文档站点需昂贵研发资源维护 CMS、部署和更新。
                  </p>
                </div>

                <!-- Card 3 -->
                <div
                  class="bg-white p-8 rounded-2xl shadow-lg border-t-4 border-secondary h-80 flex flex-col"
                >
                  <div class="text-secondary mb-6">
                    <i class="fas fa-th-large w-12 h-12"></i>
                  </div>

                  <h3 class="text-2xl font-bold text-slate-800 mb-4">
                    体验割裂
                  </h3>

                  <p class="text-slate-600">
                    不同渠道品牌声音不一。单点更新无法同步全网，导致信息滞后。
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Slide 3: Who -->
          <div class="swiper-slide">
            <div
              class="w-full h-full bg-white/60 backdrop-blur-xl rounded-3xl p-4 shadow-2xl border border-white/20 overflow-auto relative flex flex-col"
            >
              <div class="absolute top-6 right-8 z-10" x-html="logoSvg"></div>

              <header class="mb-8 border-l-8 border-primary pl-6 pr-20">
                <h1 class="text-4xl font-black text-slate-800 mb-2">
                  面向谁？
                </h1>

                <p class="text-xl text-slate-500 font-light">
                  赋能知识密集型企业
                </p>
              </header>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-4">
