      <!-- 6. 操作控制 -->
      <section id="controls" class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-lg border border-white/20 p-6 md:p-8">
        <h2 class="text-3xl font-bold text-slate-800 mb-4">6. 操作控制</h2>
        <div class="prose prose-slate max-w-none">
          <h3 class="text-xl font-semibold text-slate-800 mt-6 mb-3">幻灯片控制</h3>
          <div class="space-y-4">
            <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
              <h4 class="font-bold text-slate-800 mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                </svg>
                目录菜单
              </h4>
              <p class="text-sm text-slate-600">点击左上角"目录"按钮打开导航菜单，可以快速跳转到任意幻灯片</p>
            </div>

            <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
              <h4 class="font-bold text-slate-800 mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary">
                  <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
                控制按钮
              </h4>
              <p class="text-sm text-slate-600">使用底部控制栏的"上一张"和"下一张"按钮切换幻灯片</p>
            </div>

            <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
              <h4 class="font-bold text-slate-800 mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                  <line x1="9" y1="3" x2="9" y2="21"></line>
                </svg>
                键盘控制
              </h4>
              <ul class="text-sm text-slate-600 space-y-1 mt-2">
                <li>• <kbd class="bg-slate-200 px-2 py-1 rounded text-xs">←</kbd> 或 <kbd class="bg-slate-200 px-2 py-1 rounded text-xs">↑</kbd>：上一张</li>
                <li>• <kbd class="bg-slate-200 px-2 py-1 rounded text-xs">→</kbd> 或 <kbd class="bg-slate-200 px-2 py-1 rounded text-xs">↓</kbd>：下一张</li>
                <li>• <kbd class="bg-slate-200 px-2 py-1 rounded text-xs">Home</kbd>：第一张</li>
                <li>• <kbd class="bg-slate-200 px-2 py-1 rounded text-xs">End</kbd>：最后一张</li>
