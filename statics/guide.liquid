{% comment %} AIPPT 模板操作指南 {% endcomment %}

<div class="min-h-screen bg-primary-100">
  <!-- 左侧目录导航 - 固定悬停 -->
  <aside class="fixed left-0 top-0 h-screen w-64 bg-white/60 backdrop-blur-xl border-r border-white/20 flex flex-col z-40">
    <!-- 标题区域 - 固定 -->
    <div class="flex items-center gap-2 bg-primary/80 backdrop-blur-xl border-b border-white/20 px-6 py-4 flex-shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 w-6 h-6 text-white">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
      </svg>
      <h2 class="text-xl font-bold text-white">操作指南</h2>
    </div>

    <!-- 导航区域 - 可滚动 -->
    <nav class="flex-1 overflow-y-auto p-4">
      <ul class="space-y-1">
        <li>
          <a href="#overview" class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-100 hover:text-primary transition-colors text-sm">
            <span class="flex-1">1. 模板概述</span>
          </a>
        </li>
        <li>
          <a href="#create-channel" class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-100 hover:text-primary transition-colors text-sm">
            <span class="flex-1">2. 创建 PPT 幻灯片栏目</span>
          </a>
        </li>
        <li>
          <a href="#create-slides" class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-100 hover:text-primary transition-colors text-sm">
            <span class="flex-1">3. 创建幻灯片</span>
          </a>
        </li>
        <li>
          <a href="#edit-content" class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-100 hover:text-primary transition-colors text-sm">
            <span class="flex-1">4. 编辑幻灯片内容</span>
          </a>
        </li>
        <li>
          <a href="#component-library" class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-100 hover:text-primary transition-colors text-sm">
            <span class="flex-1">5. 使用组件库</span>
          </a>
        </li>
        <li>
          <a href="#controls" class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-100 hover:text-primary transition-colors text-sm">
            <span class="flex-1">6. 操作控制</span>
          </a>
        </li>
        <li>
          <a href="#tips" class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-100 hover:text-primary transition-colors text-sm">
            <span class="flex-1">7. 使用技巧</span>
          </a>
        </li>
        <li>
          <a href="#faq" class="flex items-center gap-2 px-4 py-2.5 rounded-lg text-slate-700 hover:bg-slate-100 hover:text-primary transition-colors text-sm">
            <span class="flex-1">8. 常见问题</span>
          </a>
        </li>
      </ul>
    </nav>
  </aside>

  <!-- 右侧主内容区域 -->
  <main class="ml-64 py-12 px-4 md:px-8">
    <div class="max-w-4xl mx-auto">
      <!-- 页面标题 -->
      <div class="mb-12 text-center">
        <h1 class="text-4xl md:text-5xl font-black text-slate-800 mb-4">
          AIPPT 模板操作指南
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed">
          通过本指南快速了解如何使用 AIPPT 模板创建精美的 PPT 幻灯片和组件库
        </p>
      </div>

      <!-- 内容区域 -->
      <div class="space-y-8">
      <!-- 1. 模板概述 -->
      <section id="overview" class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-lg border border-white/20 p-6 md:p-8">
        <h2 class="text-3xl font-bold text-slate-800 mb-4">1. 模板概述</h2>
        <div class="prose prose-slate max-w-none">
          <p class="text-lg text-slate-600 mb-4">
            AIPPT 模板是一个强大的 PPT 幻灯片制作工具，支持通过网页创建多端适配的幻灯片效果，并内置了组件库管理功能。
          </p>

          <h3 class="text-xl font-semibold text-slate-800 mt-6 mb-3">主要功能</h3>
          <ul class="space-y-2 text-slate-600">
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary mt-0.5 flex-shrink-0">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span><strong>PPT 幻灯片展示</strong>：使用 Swiper.js 实现流畅的幻灯片切换效果</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary mt-0.5 flex-shrink-0">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span><strong>HTML 动画支持</strong>：支持完整的 HTML/CSS/JavaScript 代码，可制作丰富的动画效果</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary mt-0.5 flex-shrink-0">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span><strong>组件库管理</strong>：内置组件库功能，方便管理和复用 UI 组件</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary mt-0.5 flex-shrink-0">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span><strong>多端适配</strong>：响应式设计，支持 PC、平板、手机等多种设备</span>
            </li>
            <li class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary mt-0.5 flex-shrink-0">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span><strong>键盘控制</strong>：支持方向键、Home、End 键快速切换幻灯片</span>
            </li>
          </ul>

          <h3 class="text-xl font-semibold text-slate-800 mt-6 mb-3">页面类型</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
            <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
              <h4 class="font-bold text-slate-800 mb-2">首页 (index)</h4>
              <p class="text-sm text-slate-600">展示所有栏目列表，每个栏目对应一个 PPT 幻灯片集合</p>
            </div>
            <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
              <h4 class="font-bold text-slate-800 mb-2">栏目页 (channel)</h4>
              <p class="text-sm text-slate-600">完整的 PPT 幻灯片展示框架，包含导航菜单和控制按钮</p>
            </div>
            <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
              <h4 class="font-bold text-slate-800 mb-2">组件库 (components)</h4>
              <p class="text-sm text-slate-600">网格布局展示所有组件，支持预览、代码和提示词查看</p>
            </div>
          </div>
        </div>
      </section>

      <!-- 2. 创建 PPT 幻灯片栏目 -->
      <section id="create-channel" class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-lg border border-white/20 p-6 md:p-8">
        <h2 class="text-3xl font-bold text-slate-800 mb-4">2. 创建 PPT 幻灯片栏目</h2>
        <div class="prose prose-slate max-w-none">
          <p class="text-lg text-slate-600 mb-4">
            栏目是 PPT 幻灯片的容器，每个栏目可以包含多张幻灯片。
          </p>

          <h3 class="text-xl font-semibold text-slate-800 mt-6 mb-3">操作步骤</h3>
          <ol class="space-y-3 text-slate-600">
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">1</span>
              <div>
                <p class="font-semibold text-slate-800">在首页创建子页面</p>
                <p class="text-sm mt-1">进入后台管理，在首页下创建新的子页面</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">2</span>
              <div>
                <p class="font-semibold text-slate-800">选择模板类型</p>
                <p class="text-sm mt-1">在页面设置中选择模板为 <code class="bg-slate-100 px-2 py-1 rounded">channel</code></p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">3</span>
              <div>
                <p class="font-semibold text-slate-800">填写栏目信息</p>
                <p class="text-sm mt-1">在页面设置中填写栏目标题、描述和封面图（可选）</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">4</span>
              <div>
                <p class="font-semibold text-slate-800">保存并发布</p>
                <p class="text-sm mt-1">保存页面后，栏目会出现在首页的栏目列表中</p>
              </div>
            </li>
          </ol>

          <div class="mt-6 p-4 bg-primary-50 rounded-lg border border-primary-200">
            <p class="text-sm text-slate-700">
              <strong>💡 提示</strong>：栏目封面图建议使用 16:9 的比例，尺寸为 400px 宽度，这样在首页展示时效果最佳。
            </p>
          </div>
        </div>
      </section>

      <!-- 3. 创建幻灯片 -->
      <section id="create-slides" class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-lg border border-white/20 p-6 md:p-8">
        <h2 class="text-3xl font-bold text-slate-800 mb-4">3. 创建幻灯片</h2>
        <div class="prose prose-slate max-w-none">
          <p class="text-lg text-slate-600 mb-4">
            在栏目下创建子页面，每个子页面代表一张幻灯片。
          </p>

          <h3 class="text-xl font-semibold text-slate-800 mt-6 mb-3">操作步骤</h3>
          <ol class="space-y-3 text-slate-600">
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">1</span>
              <div>
                <p class="font-semibold text-slate-800">在栏目下创建子页面</p>
                <p class="text-sm mt-1">进入栏目页面，在后台管理中添加子页面</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">2</span>
              <div>
                <p class="font-semibold text-slate-800">选择模板类型</p>
                <p class="text-sm mt-1">选择模板为 <code class="bg-slate-100 px-2 py-1 rounded">page</code>（默认模板）</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">3</span>
              <div>
                <p class="font-semibold text-slate-800">填写幻灯片信息</p>
                <p class="text-sm mt-1">填写幻灯片标题（用于导航菜单显示）</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">4</span>
              <div>
                <p class="font-semibold text-slate-800">编辑 HTML 内容</p>
                <p class="text-sm mt-1">在"HTML内容"字段中编写幻灯片的 HTML 代码</p>
              </div>
            </li>
          </ol>

          <div class="mt-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
            <p class="text-sm text-slate-700">
              <strong>📝 注意</strong>：幻灯片的显示顺序按照创建时间排序。如果需要调整顺序，可以在后台管理中调整页面的排序。
            </p>
          </div>
        </div>
      </section>

      <!-- 4. 编辑幻灯片内容 -->
      <section id="edit-content" class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-lg border border-white/20 p-6 md:p-8">
        <h2 class="text-3xl font-bold text-slate-800 mb-4">4. 编辑幻灯片内容</h2>
        <div class="prose prose-slate max-w-none">
          <p class="text-lg text-slate-600 mb-4">
            幻灯片内容使用 HTML 代码编写，支持 TailwindCSS 类名、Font Awesome 图标和自定义 CSS/JavaScript。
          </p>

          <h3 class="text-xl font-semibold text-slate-800 mt-6 mb-3">可用资源</h3>
          <div class="space-y-4">
            <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
              <h4 class="font-bold text-slate-800 mb-2">TailwindCSS 类名</h4>
              <p class="text-sm text-slate-600 mb-2">可以使用所有 TailwindCSS 工具类，例如：</p>
              <pre class="bg-slate-900 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto"><code>&lt;div class="bg-primary text-white p-6 rounded-lg"&gt;
  内容区域
&lt;/div&gt;</code></pre>
            </div>

            <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
              <h4 class="font-bold text-slate-800 mb-2">Font Awesome 图标</h4>
              <p class="text-sm text-slate-600 mb-2">使用 Font Awesome 图标，格式：</p>
              <pre class="bg-slate-900 text-slate-100 p-4 rounded-lg text-sm overflow-x-auto"><code>&lt;i class="fas fa-icon-name w-6 h-6"&gt;&lt;/i&gt;</code></pre>
              <p class="text-xs text-slate-500 mt-2">常用图标：fa-check-circle, fa-star, fa-heart, fa-user, fa-home 等</p>
            </div>

            <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
              <h4 class="font-bold text-slate-800 mb-2">颜色系统</h4>
              <p class="text-sm text-slate-600 mb-2">模板定义了以下颜色（支持完整色阶 50-950）：</p>
              <ul class="text-sm text-slate-600 space-y-1">
                <li><code class="bg-slate-100 px-2 py-1 rounded">primary</code> - 主色调（青色）</li>
                <li><code class="bg-slate-100 px-2 py-1 rounded">secondary</code> - 次色调（橙色）</li>
                <li><code class="bg-slate-100 px-2 py-1 rounded">accent</code> - 强调色（靛蓝色）</li>
              </ul>
            </div>
          </div>

          <h3 class="text-xl font-semibold text-slate-800 mt-6 mb-3">内容示例</h3>
          <div class="bg-slate-900 rounded-lg p-6 overflow-x-auto">
            <pre class="text-slate-100 text-sm font-mono leading-relaxed"><code>&lt;!-- 简单文本幻灯片 --&gt;
&lt;div class="text-center"&gt;
  &lt;h2 class="text-4xl font-black text-slate-800 mb-8"&gt;
    标题内容
  &lt;/h2&gt;
  &lt;p class="text-2xl text-slate-600"&gt;
    描述内容
  &lt;/p&gt;
&lt;/div&gt;

&lt;!-- 带图标的卡片 --&gt;
&lt;div class="bg-white p-8 rounded-2xl shadow-lg"&gt;
  &lt;i class="fas fa-check-circle w-12 h-12 text-primary mb-4"&gt;&lt;/i&gt;
  &lt;h3 class="text-2xl font-bold"&gt;功能标题&lt;/h3&gt;
  &lt;p class="text-slate-600"&gt;功能描述&lt;/p&gt;
&lt;/div&gt;

&lt;!-- 网格布局 --&gt;
&lt;div class="grid grid-cols-3 gap-6"&gt;
  &lt;div class="bg-primary-100 p-6 rounded-lg"&gt;卡片 1&lt;/div&gt;
  &lt;div class="bg-primary-100 p-6 rounded-lg"&gt;卡片 2&lt;/div&gt;
  &lt;div class="bg-primary-100 p-6 rounded-lg"&gt;卡片 3&lt;/div&gt;
&lt;/div&gt;</code></pre>
          </div>

          <div class="mt-6 p-4 bg-yellow-50 rounded-lg border border-yellow-200">
            <p class="text-sm text-slate-700">
              <strong>⚠️ 重要提示</strong>：HTML 内容会直接渲染，请确保代码安全。建议使用 TailwindCSS 类名进行样式设计，避免内联样式和外部资源引用。
            </p>
          </div>
        </div>
      </section>

      <!-- 5. 使用组件库 -->
      <section id="component-library" class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-lg border border-white/20 p-6 md:p-8">
        <h2 class="text-3xl font-bold text-slate-800 mb-4">5. 使用组件库</h2>
        <div class="prose prose-slate max-w-none">
          <p class="text-lg text-slate-600 mb-4">
            组件库功能允许你创建、管理和复用 UI 组件，每个组件包含预览、代码和提示词信息。
          </p>

          <h3 class="text-xl font-semibold text-slate-800 mt-6 mb-3">创建组件库页面</h3>
          <ol class="space-y-3 text-slate-600">
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">1</span>
              <div>
                <p class="font-semibold text-slate-800">在首页创建子页面</p>
                <p class="text-sm mt-1">选择模板类型为 <code class="bg-slate-100 px-2 py-1 rounded">components</code></p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">2</span>
              <div>
                <p class="font-semibold text-slate-800">填写组件库信息</p>
                <p class="text-sm mt-1">填写标题和描述，设置封面图（可选）</p>
              </div>
            </li>
          </ol>

          <h3 class="text-xl font-semibold text-slate-800 mt-6 mb-3">创建组件</h3>
          <ol class="space-y-3 text-slate-600">
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">1</span>
              <div>
                <p class="font-semibold text-slate-800">在组件库下创建子页面</p>
                <p class="text-sm mt-1">选择模板类型为 <code class="bg-slate-100 px-2 py-1 rounded">component</code></p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">2</span>
              <div>
                <p class="font-semibold text-slate-800">填写组件信息</p>
                <p class="text-sm mt-1">填写组件标题、描述、提示词和 HTML 内容</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center font-bold">3</span>
              <div>
                <p class="font-semibold text-slate-800">查看组件详情</p>
                <p class="text-sm mt-1">点击组件卡片进入详情页，可以查看预览、代码和提示词</p>
              </div>
            </li>
          </ol>

          <h3 class="text-xl font-semibold text-slate-800 mt-6 mb-3">组件详情页功能</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
            <div class="bg-slate-50 rounded-lg p-4 border border-slate-200">
              <h4 class="font-bold text-slate-800 mb-2 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-primary">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
                预览
              </h4>
