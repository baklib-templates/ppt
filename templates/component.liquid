{% comment %} 组件详情页：展示组件标题、描述，以及预览/代码/提示词切换 {% endcomment %}
{% assign components = page.parent.children_in_list %}

<div class="min-h-screen bg-primary-100">
  <!-- 左侧组件列表导航 - 固定悬停 -->
  <aside class="fixed left-0 top-0 h-screen w-64 bg-white/60 backdrop-blur-xl border-r border-white/20 flex flex-col z-40">
    <!-- 标题区域 - 固定 -->
    <div class="flex items-center gap-2 bg-primary/80 backdrop-blur-xl border-b border-white/20 px-6 py-4 flex-shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8 w-8 h-8 text-secondary">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z" />
      </svg>
      <h2 class="text-xl md:text-2xl font-bold text-white">{{ page.parent.settings.title | default: page.parent.link_text }}</h2>
    </div>

    <!-- 导航区域 - 可滚动 -->
    <nav class="flex-1 overflow-y-auto p-4">
      <ul class="space-y-1">
        {% for component in components %}
          {% assign is_active = false %}
          {% if page and page.id == component.id %}
            {% assign is_active = true %}
          {% endif %}

          <li>
            <a
              href="{{ component.url }}"
              class="flex items-center gap-3 px-4 py-2.5 rounded-lg transition-colors {% if is_active %}bg-primary text-white shadow-sm{% else %}text-slate-700 hover:bg-slate-100 hover:text-primary{% endif %}"
            >
              <span class="flex-1 font-medium text-sm truncate">
                {{ component.settings.title | default: component.link_text }}
              </span>
              {% if is_active %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 flex-shrink-0">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              {% endif %}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <!-- 底部导航 - 固定在底部 -->
    <div class="flex-shrink-0 border-t border-primary/20 px-4" id="footer_nav">
      <ul class="space-y-2">
        <li>
          <a href="/s/guide" class="flex items-center gap-2 px-3 py-2 rounded-lg text-slate-700 hover:bg-slate-100 hover:text-primary transition-colors text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            <span>操作指南</span>
          </a>
        </li>
      </ul>
    </div>
  </aside>

  <!-- 右侧组件详情区域 -->
  <main class="ml-64 overflow-y-auto">
    {% if page %}
      {% render "component", page: page %}
    {% else %}
      <div class="flex items-center justify-center min-h-screen">
        <div class="text-center text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mx-auto mb-4">
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
          <p class="text-lg">暂无组件</p>
        </div>
      </div>
    {% endif %}
  </main>
</div>

{% schema %}
  {
    "name": "Slide 组件",
    "description": "PPT 幻灯片单页组件",
    "thumb_url": "images/theme/thumb.png",
    "preview_image_urls": [
      "images/theme/component.webp"
    ],
    "sub_page_templates": ["component"],
    "settings": [
      {
        "id": "title",
        "type": "text",
        "label": "标题",
        "info": "组件标题",
        "placeholder": "请输入组件标题"
      },
      {
        "id": "description",
        "type": "textarea",
        "label": "描述",
        "info": "组件描述",
        "placeholder": "请输入组件描述",
        "rows": 3
      },
      {
        "id": "prompt",
        "type": "textarea",
        "label": "提示词",
        "info": "组件提示词",
        "placeholder": "请输入组件提示词",
        "rows": 10
      },
      {
        "id": "html_content",
        "type": "html",
        "label": "HTML内容",
        "info": "组件HTML内容，支持HTML代码和动画效果",
        "rows": 20,
        "placeholder": "请输入HTML内容..."
      }
    ]
  }
{% endschema %}
