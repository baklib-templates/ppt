{% comment %} 组件详情页：展示组件标题、描述，以及预览/代码/提示词切换 {% endcomment %}

<main class="container mx-auto px-4 py-8">
  {{ page.settings.html_content }}
</main>


{% schema %}
  {
    "name": "Slide 组件",
    "description": "PPT 幻灯片单页组件",
    "thumb_url": "images/theme/thumb-component.webp",
    "preview_image_urls": [
      "images/theme/component.webp"
    ],
    "sub_page_templates": ["component"],
    "settings": [
      {
        "id": "title",
        "type": "text",
        "label": "标题",
        "info": "组件标题",
        "placeholder": "请输入组件标题"
      },
      {
        "id": "description",
        "type": "textarea",
        "label": "描述",
        "info": "组件描述",
        "placeholder": "请输入组件描述",
        "rows": 3
      },
      {
        "id": "prompt",
        "type": "textarea",
        "label": "提示词",
        "info": "组件提示词",
        "placeholder": "请输入组件提示词",
        "rows": 10
      },
      {
        "id": "html_content",
        "type": "html",
        "label": "HTML内容",
        "info": "组件HTML内容，支持HTML代码和动画效果",
        "rows": 20,
        "placeholder": "请输入HTML内容..."
      }
    ]
  }
{% endschema %}
