{% comment %} 组件库展示页：左侧组件列表 + 右侧当前组件详情（通过 slug 决定 current_page） {% endcomment %}

{%- assign components = page.children_in_list -%}
{%- assign current_slug = params.slug -%}
{%- assign current_page = nil -%}

{%- if current_slug -%}
  {%- for component in components -%}
    {%- if component.slug == current_slug -%}
      {%- assign current_page = component -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if current_page == nil and components.size > 0 -%}
  {%- assign current_page = components.first -%}
{%- endif -%}

<div class="min-h-screen bg-primary-100" x-data="{ sidebarOpen: false }" x-init="sidebarOpen = window.innerWidth >= 768">
  <!-- 左侧组件列表导航 - 固定悬停 -->
  <aside
    class="fixed left-0 top-0 h-screen w-64 bg-white/60 backdrop-blur-xl border-r border-white/20 flex flex-col z-40 transition-transform duration-300 ease-in-out"
    :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'"
  >
    <!-- 标题区域 - 固定 -->
    <div class="flex items-center justify-between gap-2 bg-primary/80 backdrop-blur-xl border-b border-white/20 px-6 py-4 flex-shrink-0">
      <div class="flex items-center gap-2 flex-1 min-w-0">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8 w-8 h-8 text-white flex-shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z" />
        </svg>
        <h2 class="text-xl md:text-2xl font-bold text-white truncate">{{ page.settings.title | default: page.link_text }}</h2>
      </div>
      <!-- 展开/折叠按钮 -->
      <button
        @click="sidebarOpen = !sidebarOpen"
        class="flex-shrink-0 p-1.5 rounded-lg text-white hover:bg-white/20 transition-colors"
        :aria-label="sidebarOpen ? '折叠侧边栏' : '展开侧边栏'"
      >
        <svg x-show="!sidebarOpen" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg x-show="sidebarOpen" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- 导航区域 - 可滚动 -->
    <nav class="flex-1 overflow-y-auto p-4">
      <ul class="space-y-1">
        {% for component in components %}
          {% assign is_active = false %}
          {% if current_page and current_page.id == component.id %}
            {% assign is_active = true %}
          {% endif %}

          <li>
            <a
              href="{{ page.url }}?slug={{ component.slug }}"
              class="flex items-center gap-3 px-4 py-2.5 rounded-lg transition-colors {% if is_active %}bg-secondary text-white shadow-sm{% else %}text-slate-700 hover:bg-slate-100 hover:text-primary{% endif %}"
            >
              <span class="flex-1 font-medium text-sm truncate">
                {{ component.settings.title | default: component.link_text }}
              </span>
              {% if is_active %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 flex-shrink-0">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              {% endif %}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <!-- 底部导航 - 固定在底部 -->
    <div class="flex-shrink-0 border-t border-primary/20 px-4" id="footer_nav">
      <ul class="flex justify-between gap-0 py-2">
        <li>
          <a href="/s/guide" class="flex items-center gap-2 transition-colors text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            <span>操作指南</span>
          </a>
        </li>
        <li>
          <a href="/" class="flex items-center gap-2 transition-colors text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
            <span>返回首页</span>
          </a>
        </li>
      </ul>
    </div>
  </aside>

  <!-- 移动端遮罩层 -->
  <div
    x-show="sidebarOpen"
    @click="sidebarOpen = false"
    x-transition:enter="transition-opacity ease-out duration-300"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition-opacity ease-in duration-200"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="fixed inset-0 bg-black/50 z-30 md:hidden"
    style="display: none;"
  ></div>

  <!-- 移动端展开按钮（当侧边栏折叠时显示） -->
  <button
    @click="sidebarOpen = true"
    x-show="!sidebarOpen"
    class="fixed top-4 left-4 z-50 p-3 bg-primary/80 backdrop-blur-xl text-white rounded-lg shadow-lg hover:bg-primary transition-colors"
    style="display: none;"
    aria-label="展开侧边栏"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
  </button>

  <!-- 右侧组件详情区域 -->
  <main class="overflow-y-auto transition-all duration-300" :class="sidebarOpen ? 'md:ml-64' : 'md:ml-0'">
    {% if current_page %}
      {% render "component", page: current_page %}
    {% else %}
      <div class="flex items-center justify-center min-h-screen">
        <div class="text-center text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-16 h-16 mx-auto mb-4">
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
          <p class="text-lg"><i class="fa fa-arrow-left"></i> 点击左侧导航查看组件</p>
        </div>
      </div>
    {% endif %}
  </main>
</div>


{% schema %}
  {
    "name": "Slide Components",
    "description": "PPT 幻灯片组件库",
    "thumb_url": "images/theme/thumb-components.webp",
    "preview_image_urls": [
      "images/theme/components.webp"
    ],
    "sub_page_templates": ["component"],
    "settings": [
      {
        "id": "title",
        "type": "text",
        "label": "标题",
        "info": "栏目标题",
        "default": "Tailwind CSS UI Components"
      },
      {
        "id": "description",
        "type": "textarea",
        "label": "描述",
        "info": "栏目描述",
        "rows": 3,
        "default": "A collection of beautiful, ready-to-use Tailwind CSS UI components. These components are highly customizable and perfect for building modern web applications."
      },
      {
        "id": "thumb_image_url",
        "type": "image_picker",
        "ratio": "16:9",
        "width": 400,
        "label": "封面图",
        "info": "栏目封面图片"
      }
    ]
  }
{% endschema %}
