{% comment %} PDF 版本栏目页：从上到下显示所有子页面内容，适合打印为 PDF {% endcomment %}
{% assign slides = page.children_in_list %}
{% assign slides_count = slides | size %}


  <style>
    /* 打印样式优化 */
    @media print {
      @page {
        size: A4 landscape;
        margin: 2cm;
      }

      * {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        color-adjust: exact;
      }

      body {
        margin: 0;
        padding: 0;
        background: white;
      }

      .slide-page {
        page-break-after: always;
        break-after: page;
        margin: 0;
        padding: 2cm;
        box-shadow: none;
        border-radius: 0;
        min-height: auto;
        display: flex;
      }

      .slide-page:last-child {
        page-break-after: auto;
      }

      .no-break {
        page-break-inside: avoid;
        break-inside: avoid;
      }

      /* 隐藏不需要打印的元素 */
      .no-print {
        display: none !important;
      }

      /* 确保链接在打印时可见 */
      a {
        color: inherit;
        text-decoration: underline;
      }
    }

    /* 屏幕显示样式 */
    @media screen {
      body {
        background-color: #ffffff;
        padding: 2rem;
      }

      .slide-page {
        margin-bottom: 2rem;
      }
    }

    /* 通用样式 */
    body {
      font-family: "Noto Sans SC", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: #1e293b;
      line-height: 1.6;
    }

    .slide-page {
      border-radius: 1rem;
      padding: 3rem;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: center;
      text-align: center;
      min-height: auto;
    }

    .slide-content {
      width: 100%;
      max-width: 100%;
    }

  </style>

  <main class="container mx-auto max-w-5xl">
    {% comment %} 显示所有子页面内容 {% endcomment %}
    {% for slide in slides %}
      <div class="slide-page no-break">
        <div class="slide-content">
          <div class="content-wrapper">
            {{ slide.settings.html_content }}
          </div>
        </div>
      </div>
    {% endfor %}

    {% comment %} 结语页：与 channel.liquid「结语幻灯片」板块一致 {% endcomment %}
    <div class="slide-page no-break">
      <div
        class="w-full h-full bg-secondary backdrop-blur-xl text-white p-12 shadow-2xl rounded-3xl border border-white/10 overflow-hidden relative flex flex-col items-center justify-center text-center"
      >
        <div class="flex flex-col items-center justify-center gap-2">
          {% assign default_logo = 'images/theme/logo-white.svg' | asset_url %}
          <img
            src="{{ site.settings.logo_url | default: default_logo }}"
            alt="{{ site.name | escape }}"
            class="h-32 object-contain"
          >
        </div>

        <h2 class="text-3xl lg:text-4xl text-black mb-6">
          {{ site.settings.company_name }}
        </h2>
        <div class="flex max-w-6xl mx-auto text-base lg:text-xl text-slate-600 leading-relax leading-5 md:leading-8">
          {{ site.settings.company_descriptionn }}
        </div>

        <div class="mt-16 text-primary-500">
          <a href="{{ site.settings.company_website_url }}" target="_blank" rel="noopener noreferrer">{{ site.settings.company_website_url }}</a>
        </div>
      </div>
    </div>
  </main>

{% schema %}
  {
    "name": "栏目页 - PDF 版本",
    "description": "PDF 版本栏目页，从上到下显示所有子页面内容，适合打印为 PDF",
    "thumb_url": "images/theme/thumb-pdf.webp",
    "preview_image_urls": [
      "images/theme/channel-pdf.webp"
    ],
    "sub_page_templates": ["page"],
    "settings": [
      {
        "id": "title",
        "type": "text",
        "label": "标题",
        "info": "栏目标题"
      },
      {
        "id": "description",
        "type": "textarea",
        "label": "描述",
        "info": "栏目描述"
      },
      {
        "id": "thumb_image_url",
        "type": "image_picker",
        "ratio": "16:9",
        "width": 400,
        "label": "封面图",
        "info": "栏目封面图片"
      }
    ]
  }
{% endschema %}
