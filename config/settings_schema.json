  {
    "name": "品牌设置",
    "settings": [
      {
        "id": "logo_url",
        "type": "image_picker",
        "ratio": "6:2",
        "width": 150,
        "label": "网站 LOGO",
        "info": "展示在页头导航栏"
      },
      {
        "id": "slogan",
        "type": "text",
        "label": "网站口号",
        "default": "AI PPT 幻灯片 - 多端适配的演示文稿解决方案"
      },
      {
        "id": "company_name",
        "type": "text",
        "label": "公司名称",
        "default": "公司名称"
      },
      {
        "id": "company_descriptionn",
        "type": "textarea",
        "label": "公司介绍",
        "default": "公司简单介绍"
      },
      {
        "id": "company_website_url",
        "type": "text",
        "label": "官网 URL"
      }
    ]
  },
  {
    "name": "页头页脚设置",
    "settings": [
      {
        "id": "head_html",
        "type": "html",
        "label": "页头自定义HTML",
        "info": "在 <head> 标签内添加自定义HTML代码",
        "rows": 10
      },
      {
        "id": "header_menu",
        "type": "textarea",
        "label": "页头导航菜单设置",
        "rows": 10,
        "info": "格式：menu_name[slug{sub_menu[slug|sub_menu[slug，每行一个分栏。",
        "default": "首页[/"
      },
      {
        "id": "footer_menu",
        "type": "textarea",
        "label": "页脚菜单设置",
        "rows": 10,
        "info": "格式：menu_name[slug]{sub_menu[slug|sub_menu[slug，每行一个分栏。",
        "default": "快捷导航[/"
      },
      {
        "id": "company_info",
        "type": "html",
        "label": "页脚公司信息",
        "default": "AI PPT 幻灯片 - 通过网页制作多端适配的PPT幻灯片效果"
      },
      {
        "id": "copyright_info",
        "type": "html",
        "label": "页脚版权信息",
        "default": "Copyright © Baklib Inc. | All rights reserved."
      }
    ]
  }
]
