<div class="min-h-screen bg-primary-100 py-8 px-4">
  <div class="max-w-screen mx-auto">
    <!-- 标题和描述区域 -->
    <div class="mb-8 flex flex-col items-center justify-center">
      <h1 class="text-2xl md:text-3xl font-semibold text-slate-800 mb-2">
        {{ page.settings.title | default: page.link_text }}
      </h1>
      {% if page.settings.description %}
        <p class="text-lg text-slate-500">
          {{ page.settings.description }}
        </p>
      {% endif %}
    </div>

    <!-- Tab 切换块 -->
    <div
      x-data="{
        activeTab: 'preview',
        copied: false,
        get htmlContent() {
          const sourceTextarea = document.getElementById('html-content-source');
          return sourceTextarea ? sourceTextarea.value : '';
        },
        async copyCode() {
          if (!this.htmlContent || this.htmlContent.trim() === '') {
            alert('暂无代码可复制');
            return;
          }

          try {
            // 检查 Clipboard API 是否可用
            if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
              await navigator.clipboard.writeText(this.htmlContent);
              this.copied = true;
              setTimeout(() => {
                this.copied = false;
              }, 2000);
            } else {
              // 降级方案：使用传统方法
              this.fallbackCopy(this.htmlContent);
            }
          } catch (err) {
            // 如果 Clipboard API 失败，使用降级方案
            this.fallbackCopy(this.htmlContent);
          }
        },
        fallbackCopy(text) {
          const textarea = document.createElement('textarea');
          textarea.value = text;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          textarea.style.left = '-9999px';
          textarea.style.top = '0';
          document.body.appendChild(textarea);
          textarea.focus();
          textarea.select();

          try {
            const successful = document.execCommand('copy');
            if (successful) {
              this.copied = true;
              setTimeout(() => {
                this.copied = false;
              }, 2000);
            } else {
              alert('复制失败，请手动复制');
            }
          } catch (err) {
            alert('复制失败，请手动复制');
          }

          document.body.removeChild(textarea);
        }
      }"
      class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/20 overflow-hidden"
    >
      <!-- Tab 导航栏 -->
      <div class="flex items-center justify-between border-b border-slate-200 bg-slate-50/50 px-6 py-4">
        <div class="flex items-center gap-2">
          <!-- 预览 Tab -->
          <button
            @click="activeTab = 'preview'"
            :class="activeTab === 'preview' ? 'bg-primary text-white shadow-sm' : 'text-slate-600 hover:text-primary hover:bg-slate-100'"
            class="flex items-center gap-2 px-4 py-2 rounded-lg font-medium transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
            <span>预览</span>
          </button>

          <!-- 代码 Tab -->
          <button
            @click="activeTab = 'code'"
            :class="activeTab === 'code' ? 'bg-primary text-white shadow-sm' : 'text-slate-600 hover:text-primary hover:bg-slate-100'"
            class="flex items-center gap-2 px-4 py-2 rounded-lg font-medium transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
              <path fill-rule="evenodd" d="M14.447 3.027a.75.75 0 0 1 .527.92l-4.5 16.5a.75.75 0 0 1-1.448-.394l4.5-16.5a.75.75 0 0 1 .921-.526ZM16.72 6.22a.75.75 0 0 1 1.06 0l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 1 1-1.06-1.06L21.44 12l-4.72-4.72a.75.75 0 0 1 0-1.06Zm-9.44 0a.75.75 0 0 1 0 1.06L2.56 12l4.72 4.72a.75.75 0 0 1-1.06 1.06L.97 12.53a.75.75 0 0 1 0-1.06l5.25-5.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
            </svg>
            <span>代码</span>
          </button>

          <!-- 提示词 Tab -->
          <button
            @click="activeTab = 'prompt'"
            :class="activeTab === 'prompt' ? 'bg-primary text-white shadow-sm' : 'text-slate-600 hover:text-primary hover:bg-slate-100'"
            class="flex items-center gap-2 px-4 py-2 rounded-lg font-medium transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
            </svg>

            <span>提示词</span>
          </button>
        </div>

        <!-- 复制代码按钮 -->
        <button
          @click="copyCode()"
          class="flex space-x-1 items-center p-2 rounded-lg text-slate-400 hover:text-primary hover:bg-slate-100 transition-colors relative"
          :class="copied ? 'text-green-500' : ''"
          :title="copied ? '已复制！' : '复制代码'"
        >
          <svg x-show="!copied" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg x-show="copied" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>复制代码</span>
        </button>
      </div>

      <!-- Tab 内容区域 -->
      <div class="">
        <!-- 预览 Tab 内容 -->
        <div x-show="activeTab === 'preview'" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100">
          {% if page.settings.html_content %}
            <div class="w-full overflow-auto p-6 md:p-8">
              {{ page.settings.html_content }}
            </div>
          {% else %}
            <div class="text-center py-12 text-slate-400">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 mx-auto mb-4">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              <p>暂无预览内容</p>
            </div>
          {% endif %}
        </div>

        <!-- 代码 Tab 内容 -->
        <div x-show="activeTab === 'code'" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100">
          {% if page.settings.html_content %}
            <!-- 隐藏的 textarea 用于复制 -->
            <textarea id="html-content-source" style="position: absolute; left: -9999px; opacity: 0;" readonly>{{ page.settings.html_content }}</textarea>
            <div class="bg-slate-900 overflow-auto p-4 md:p-8 max-h-[600px]">
              <pre class="text-slate-100 text-sm font-mono leading-relaxed whitespace-pre-wrap"><code>{{ page.settings.html_content | escape }}</code></pre>
            </div>
          {% else %}
            <div class="text-center py-12 text-slate-400">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-12 h-12 mx-auto mb-4">
                <path fill-rule="evenodd" d="M14.447 3.027a.75.75 0 0 1 .527.92l-4.5 16.5a.75.75 0 0 1-1.448-.394l4.5-16.5a.75.75 0 0 1 .921-.526ZM16.72 6.22a.75.75 0 0 1 1.06 0l5.25 5.25a.75.75 0 0 1 0 1.06l-5.25 5.25a.75.75 0 1 1-1.06-1.06L21.44 12l-4.72-4.72a.75.75 0 0 1 0-1.06Zm-9.44 0a.75.75 0 0 1 0 1.06L2.56 12l4.72 4.72a.75.75 0 0 1-1.06 1.06L.97 12.53a.75.75 0 0 1 0-1.06l5.25-5.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
              </svg>
              <p>暂无代码内容</p>
            </div>
          {% endif %}
        </div>

        <!-- 提示词 Tab 内容 -->
        <div x-show="activeTab === 'prompt'" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100">
          {% if page.settings.prompt %}
            <div class="bg-slate-50 rounded-lg p-4 md:p-8">
              <textarea
                class="w-full text-slate-700 text-base font-mono leading-relaxed bg-transparent border border-slate-200 rounded-lg p-4 focus:ring-2 focus:ring-primary focus:border-primary outline-none resize-y min-h-[400px]"
                rows="20"
                placeholder="请输入提示词内容..."
              >{{ page.settings.prompt }}</textarea>
            </div>
          {% else %}
            <div class="text-center py-12 text-slate-400">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 mx-auto mb-4">
                <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                <path d="M2 17l10 5 10-5"></path>
                <path d="M2 12l10 5 10-5"></path>
              </svg>
              <p>暂无提示词内容</p>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>
