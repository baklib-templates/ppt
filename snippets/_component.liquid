          {% if page.settings.html_content %}
            <!-- 隐藏的 textarea 用于复制 -->
            <textarea id="html-content-source" style="position: absolute; left: -9999px; opacity: 0;" readonly>{{ page.settings.html_content | escape}}</textarea>
            <div class="bg-slate-900 overflow-auto p-4 md:p-8 max-h-[800px]">
          <pre class="text-slate-100 text-sm font-mono leading-relaxed whitespace-pre-wrap"><code>{{ page.settings.html_content | escape }}</code></pre>
            </div>
          {% else %}
