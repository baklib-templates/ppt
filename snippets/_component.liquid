<div class="min-h-screen bg-primary-100 py-8 px-4">
  <div class="max-w-screen mx-auto">
    <!-- 标题和描述区域 -->

    <!-- Tab 切换块 -->
    <div
      x-data="{
        activeTab: 'preview',
        copied: false,
        get htmlContent() {
          const sourceTextarea = document.getElementById('html-content-source');
          return sourceTextarea ? sourceTextarea.value : '';
        },
        async copyCode() {
          if (!this.htmlContent || this.htmlContent.trim() === '') {
            alert('暂无代码可复制');
            return;
          }

          try {
            // 检查 Clipboard API 是否可用
            if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
              await navigator.clipboard.writeText(this.htmlContent);
              this.copied = true;
              setTimeout(() => {
                this.copied = false;
              }, 2000);
            } else {
              // 降级方案：使用传统方法
              this.fallbackCopy(this.htmlContent);
            }
          } catch (err) {
            // 如果 Clipboard API 失败，使用降级方案
            this.fallbackCopy(this.htmlContent);
          }
        },
        fallbackCopy(text) {
          const textarea = document.createElement('textarea');
          textarea.value = text;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          textarea.style.left = '-9999px';
          textarea.style.top = '0';
          document.body.appendChild(textarea);
          textarea.focus();
          textarea.select();

          try {
            const successful = document.execCommand('copy');
            if (successful) {
              this.copied = true;
              setTimeout(() => {
                this.copied = false;
              }, 2000);
            } else {
              alert('复制失败，请手动复制');
            }
          } catch (err) {
            alert('复制失败，请手动复制');
          }

          document.body.removeChild(textarea);
        }
      }"
      class="bg-white/80 backdrop-blur-xl rounded-2xl shadow-2xl border border-white/20 overflow-hidden"
    >
      <!-- Tab 导航栏 -->
      <div class="flex items-center justify-between border-b border-slate-200 bg-slate-50/50 px-6 py-4">
        <div class="flex items-center gap-2">
